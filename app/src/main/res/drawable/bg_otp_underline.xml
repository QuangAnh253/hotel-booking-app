<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Khi đang chọn ô này (Focus) -->
    <item android:state_focused="true">
        <layer-list>
            <item android:bottom="0dp" android:left="-10dp" android:right="-10dp" android:top="-10dp">
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="#e8952f" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Mặc định -->
    <item>
        <layer-list>
            <item android:bottom="0dp" android:left="-10dp" android:right="-10dp" android:top="-10dp">
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#BDBDBD" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>